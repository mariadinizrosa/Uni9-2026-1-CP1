@model SeuProjeto.Models.Aluno

@{
    ViewBag.Title = "Confirmação";
}

<h2 style="color: green;">Cadastro realizado com sucesso!</h2>

<p>Os dados do aluno foram cadastrados com sucesso.</p>

<hr />

<p><strong>Nome:</strong> @Model.Nome</p>
<p><strong>E-mail:</strong> @Model.Email</p>
<p><strong>RA:</strong> @Model.RA</p>
<p><strong>Data de Nascimento:</strong> @Model.DataNascimento.ToString("dd/MM/yyyy")</p>

<br />

<a href="@Url.Action("Cadastrar", "Aluno")">
    Cadastrar outro
</a>